# Server configuration
PORT=8080

# Set to "development" to skip serving embedded static files
# (use Vite dev server on port 5173 instead)
MODE=development

# Database — connects to Supabase's local Postgres (started via `supabase start`)
# Leave empty to run without a database connection
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# For production: use your Supabase project's database connection string

# Test database — used by "go test" and CI (standalone Postgres, not Supabase)
DATABASE_URL_TEST=postgres://localhost:5432/permission_slip_test?sslmode=disable

# API base URL — override the default "/api" prefix used by the frontend
# VITE_API_BASE_URL=/api/v1

# Supabase — used by the React frontend
# Run `supabase status` to get your local credentials (see README step 5)
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-anon-key-from-supabase-status

# Supabase — Go backend JWT authentication
#
# Supabase CLI v2+ signs JWTs with ES256 (asymmetric). The backend fetches
# the public key from the JWKS endpoint automatically if SUPABASE_URL is set.
# SUPABASE_JWT_SECRET is only needed for legacy CLI v1 or test overrides.
#
# For local dev: set SUPABASE_URL. The JWKS URL is derived automatically.
# For production: set SUPABASE_URL to your project URL (https://xxx.supabase.co).
SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_JWKS_URL=http://127.0.0.1:54321/auth/v1/.well-known/jwks.json  # optional override
# SUPABASE_JWT_SECRET=your-jwt-secret  # legacy HS256 only — not needed for CLI v2+

# Supabase service_role key — required for Admin API operations (e.g. deleting
# auth users on account deletion). Get from `supabase status` (local dev) or
# your Supabase project dashboard (production).
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Billing — set to "true" to enable billing features (Stripe integration,
# request metering, plan limits). When false (default), all users are
# auto-assigned the unlimited pay_as_you_go plan so the application runs
# without Stripe keys or billing restrictions. Self-hosted deployments
# should leave this unset or set to "false".
# BILLING_ENABLED=false

# Allowed CORS origins — comma-separated list of origins permitted to make
# cross-origin requests to the API. When empty, the server operates in
# "same-origin only" mode: requests whose Origin matches the server's own
# Host are allowed; all other cross-origin requests are blocked.
# Example: https://app.permissionslip.dev,https://staging.permissionslip.dev
ALLOWED_ORIGINS=

# Public base URL — used to construct invite URLs for agent registration
# Example: https://app.permissionslip.dev
BASE_URL=

# HMAC key for hashing invite codes — if set, uses HMAC-SHA256 instead of plain SHA-256
# Generate with: openssl rand -hex 32
INVITE_HMAC_KEY=

# Supabase Vault — encryption key for credential secrets (AES-256-GCM)
# Required when running with Supabase (supabase start). Not needed for CI/tests
# (tests use MockVaultStore). Generate with: openssl rand -hex 32
VAULT_SECRET_KEY=your-vault-secret-key-from-openssl-rand

# Trusted proxy header — the HTTP header used to extract the real client IP
# when running behind a reverse proxy. Default: "Fly-Client-IP" (set by Fly.io's
# proxy, not spoofable). Set to "X-Forwarded-For" or "X-Real-IP" for other
# proxies. Set to empty string to disable and use RemoteAddr directly.
# Only used in production mode (rate limiting must be enabled).
# TRUSTED_PROXY_HEADER=Fly-Client-IP

# Graceful shutdown timeout — how long the server waits for in-flight requests
# to complete before force-closing. Accepts Go duration syntax (e.g. "30s", "1m").
# Default: 30s
# SHUTDOWN_TIMEOUT=30s

# Custom connectors — override the directory where external connectors are
# installed and loaded from. Defaults to ~/.permission_slip/connectors/.
# On platforms like Heroku, set this to a path inside the app slug (e.g. /app/connectors)
# so connectors survive dyno restarts.
# CONNECTORS_DIR=

# Custom connectors — provide the connector list as inline JSON instead of
# requiring a custom-connectors.json file on disk. When set, the
# install-connectors command reads from this env var instead of the file.
# Example: CUSTOM_CONNECTORS_JSON={"connectors":[{"repo":"https://github.com/acme/ps-jira-connector","ref":"v1.0.0"}]}
# CUSTOM_CONNECTORS_JSON=

# Notifications
#
# Each notification channel is enabled by setting its required env vars.
# When no channel env vars are set, the server starts with notifications
# disabled (a warning is logged at startup).

# ── Email (pick one provider) ────────────────────────────────────────────────
#
# Twilio SendGrid (recommended — single API key, no SMTP config):
# NOTIFICATION_EMAIL_PROVIDER=twilio-sendgrid
# SENDGRID_API_KEY=SG.xxxx
# NOTIFICATION_EMAIL_FROM=approvals@mycompany.com
#
# Generic SMTP (Gmail app password, Mailgun, self-hosted Postfix, etc.):
# NOTIFICATION_EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=me@gmail.com
# SMTP_PASSWORD=app-password-here
# NOTIFICATION_EMAIL_FROM=me@gmail.com

# ── Web Push (VAPID) — optional channel ───────────────────────────────────────
#
# VAPID keys authenticate the server to push services (FCM, Mozilla Push, etc.).
#
# PRODUCTION: Set all three to enable Web Push. If none are set, Web Push is
#             disabled. If some are set, the server will refuse to start.
# DEVELOPMENT: Optional. If not set, the server auto-generates a key pair and
#              stores it in the database for convenience.
#
# Generate a key pair:
#   make generate-vapid-keys          # or: go run ./cmd/generate-vapid-keys
#
# Then set the output as env vars (e.g. for Fly.io):
#   fly secrets set VAPID_PUBLIC_KEY=... VAPID_PRIVATE_KEY=... VAPID_SUBJECT=mailto:admin@mycompany.com
#
# WARNING: Changing VAPID keys will invalidate all existing Web Push subscriptions.
# Users will need to re-subscribe to push notifications.
#
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@mycompany.com

# ── SMS (Twilio) ─────────────────────────────────────────────────────────────
# All three required to enable SMS notifications.
# TWILIO_ACCOUNT_SID=ACxxxx
# TWILIO_AUTH_TOKEN=xxxx
# TWILIO_FROM_NUMBER=+15551234567

# ── Error Tracking (Sentry) ──────────────────────────────────────────────────
#
# When SENTRY_DSN is not set, Sentry is disabled (no-op in dev/test).
# The free tier includes 5,000 errors/month and 10,000 performance
# transactions/month. Only 5xx errors and panics are captured — 4xx client
# errors are not reported.
#
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
#
# CSP violation reporting — optional. When set, the server adds a report-uri
# directive to the Content-Security-Policy header so CSP violations are
# captured as Sentry events. Get the URL from your Sentry project:
# Settings → Security Headers → report-uri.
# SENTRY_CSP_ENDPOINT=https://o0.ingest.sentry.io/api/0/security/?sentry_key=abc

# ── Product Analytics (PostHog) ─────────────────────────────────────────────
#
# PostHog is disabled when VITE_POSTHOG_KEY is not set. Events are only
# sent after the user accepts the cookie consent banner.
#
# VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VITE_POSTHOG_HOST=https://us.i.posthog.com
#
# Backend CSP — must match VITE_POSTHOG_HOST so the browser can send
# events. Only needed in production (Vite dev server has no CSP).
# POSTHOG_HOST=https://us.i.posthog.com

# VITE_REACT_DEVTOOLS=true  # Uncomment to connect to standalone react-devtools app (npm run devtools)
