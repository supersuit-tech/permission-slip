    "express": "^5.2.1",
    "http-proxy": "^1.18.1",
    "jsdom": "^29.0.2",
    "openapi-typescript": "^7.13.0",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.1.18",
    "typescript": "^6.0.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.5"
