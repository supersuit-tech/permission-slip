# Environment files
.env
.env.*
!.env.example

# Go
bin/
/seed

# Node (matches all directories: frontend/, mobile/, etc.)
node_modules/
*.tsbuildinfo

# Vite build output (keep .gitkeep so embed compiles)
frontend/dist/*
!frontend/dist/.gitkeep

# CLI build output (compiled TypeScript)
cli/dist/

# Generated API types (generated by npm run generate:api from spec/openapi/openapi.bundle.yaml)
frontend/src/api/schema.d.ts
mobile/src/api/schema.d.ts

# Expo / React Native (mobile/.gitignore covers Expo-specific artifacts;
# only project-specific generated files need listing here)
mobile/src/api/schema.d.ts

# Storybook build output
storybook-static/

# Custom connectors config (user-specific, not checked in)
custom-connectors.json
