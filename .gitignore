# Generated API types (generated by npm run generate:api from spec/openapi/openapi.bundle.yaml)
frontend/src/api/schema.d.ts

# Expo / React Native (mobile/)
mobile/node_modules/
mobile/.expo/
mobile/dist/
mobile/web-build/
mobile/expo-env.d.ts
mobile/ios/
mobile/android/
mobile/.metro-health-check*

# Generated mobile API types
mobile/src/api/schema.d.ts

# Custom connectors config (user-specific, not checked in)
custom-connectors.json
